{
  "info": {
    "name": "Testing System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tests",
      "item": [
        {
          "name": "Get All Tests",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8080/api/tests" }
          }
        },
        {
          "name": "Get Test By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8080/api/tests/1" }
          }
        },
        {
          "name": "Create Test",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/api/tests" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Test\",\n  \"subject\": \"Mathematics\"\n}"
            }
          }
        },
        {
          "name": "Update Test",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/api/tests/1" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Test\",\n  \"subject\": \"Updated Subject\"\n}"
            }
          }
        },
        {
          "name": "Delete Test",
          "request": {
            "method": "DELETE",
            "url": { "raw": "http://localhost:8080/api/tests/1" }
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "Get Questions By Test",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8080/api/questions/test/1" }
          }
        },
        {
          "name": "Create Question (SINGLE)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/api/questions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"testId\": 1,\n  \"text\": \"What is 2 + 2?\",\n  \"type\": \"SINGLE\",\n  \"options\": [\"3\", \"4\", \"5\", \"6\"],\n  \"correctAnswers\": [1]\n}"
            }
          }
        },
        {
          "name": "Create Question (MULTIPLE)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/api/questions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"testId\": 1,\n  \"text\": \"Which are prime numbers?\",\n  \"type\": \"MULTIPLE\",\n  \"options\": [\"2\", \"4\", \"7\", \"9\"],\n  \"correctAnswers\": [0, 2]\n}"
            }
          }
        },
        {
          "name": "Update Question",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/api/questions/1" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"testId\": 1,\n  \"text\": \"Updated question text?\",\n  \"type\": \"SINGLE\",\n  \"options\": [\"A\", \"B\", \"C\", \"D\"],\n  \"correctAnswers\": [0]\n}"
            }
          }
        },
        {
          "name": "Delete Question",
          "request": {
            "method": "DELETE",
            "url": { "raw": "http://localhost:8080/api/questions/1" }
          }
        }
      ]
    },
    {
      "name": "Results",
      "item": [
        {
          "name": "Submit Test",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/api/results/submit" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentName\": \"Alice\",\n  \"testId\": 1,\n  \"answers\": {\n    \"1\": [1],\n    \"2\": [0, 1, 3],\n    \"3\": [2],\n    \"4\": [0, 2]\n  }\n}"
            }
          }
        },
        {
          "name": "Get Results By Test",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8080/api/results/test/1" }
          }
        }
      ]
    }
  ]
}
